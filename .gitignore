# ====================================
# ВРЕМЕННЫЕ ФАЙЛЫ
# ====================================

# Системные файлы
.DS_Store          # macOS
Thumbs.db          # Windows
desktop.ini        # Windows

# Редакторы и IDE
.vscode/           # VS Code
.idea/             # IntelliJ IDEA
*.swp              # Vim swap files
*.swo
*~
*.iml              # IntelliJ module file

# Временные файлы
*.tmp
*.temp
*.log
*.cache

# ====================================
# ЗАВИСИМОСТИ
# ====================================

# Python
__pycache__/
*.py[cod]
*$py.class
venv/
env/
ENV/
.env
.venv
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.coverage
htmlcov/
dist/
build/
*.egg-info/

# Node.js / JavaScript
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
bower_components/

# Java
*.class
target/
*.jar
*.war
*.ear

# PHP
vendor/
composer.lock

# Ruby
vendor/bundle/
Gemfile.lock

# ====================================
# КОНФИДЕНЦИАЛЬНЫЕ ДАННЫЕ
# ====================================

# Переменные окружения
.env
.env.local
.env.production
.env.development

# Ключи и сертификаты
*.key
*.pem
*.crt
*.p12
*.pfx
*.p8

# Конфигурации с секретами
config.local.*
secrets.yml
secrets.json
credentials.json
.credentials

# API ключи
api-key.txt
api-keys.json

# ====================================
# ЛОГИ И ОТЧЕТЫ
# ====================================

*.log
logs/
*.pid
*.seed
*.pid.lock
report.html
coverage/

# ====================================
# ФАЙЛЫ СБОРКИ
# ====================================

dist/
build/
out/
*.min.js
*.min.css
*.bundle.js
*.bundle.css

# ====================================
# ОСОБЫЕ СЛУЧАИ
# ====================================

# Исключить конкретный файл (но не папку)
!important.log     # восклицательный знак включает файл

# Исключить все файлы в папке, но не саму папку
uploads/*
!uploads/.gitkeep

# Игнорировать все файлы с определенным расширением
*.bak
*.old
*.orig
